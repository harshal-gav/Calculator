{
    "redirects": [
        {
            "source": "/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "(?<host>.*.vercel.app)"
                }
            ],
            "destination": "https://calculator-all.com/$1",
            "permanent": true
        }
    ],
    "crons": [
        {
            "path": "/api/cron/linkedin-post",
            "schedule": "0 0 * * *"
        }
    ]
}