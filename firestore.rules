rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Explicitly target the "contacts" collection
    match /contacts/{document} {
      // Allow anyone (even unauthenticated users) to submit a form
      // We also enforce that the name, email, and message are strings to prevent junk data
      allow create: if 
        request.resource.data.name is string &&
        request.resource.data.email is string &&
        request.resource.data.message is string;
      
      // Prevent anyone from reading, editing, or deleting the messages from the web frontend
      allow read, update, delete: if false;
    }

    // Deny read/write access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
